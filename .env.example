# Required for Local Multiplayer
VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# SEO: Production site URL — no trailing slash. Used for:
# - Canonical URLs, Open Graph, and JSON-LD (getSiteUrl in app)
# - index.html og:image / twitter:image at build (vite.config transform)
# - public/sitemap.xml and public/robots.txt (prebuild: scripts/generate-sitemap.js)
# VITE_SITE_URL=https://yoursite.com

# Optional: debug panel (VITE_DEBUG=true or ?debug=1 in dev)
# VITE_DEBUG=false
